.PHONY : workbench/src/theme.s

# target to generate assembly for a file
workbench/src/theme.cpp.s:
	cd /Users/stephen/git/viperdos/build && $(MAKE) $(MAKESILENT) -f user/CMakeFiles/workbench.sys.dir/build.make user/CMakeFiles/workbench.sys.dir/workbench/src/theme.cpp.s
.PHONY : workbench/src/theme.cpp.s

