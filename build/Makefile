	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 test_ssh_crypto
.PHONY : test_ssh_crypto

# fast build rule for target.
test_ssh_crypto/fast:
	$(MAKE) $(MAKESILENT) -f tests/CMakeFiles/test_ssh_crypto.dir/build.make tests/CMakeFiles/test_ssh_crypto.dir/build
.PHONY : test_ssh_crypto/fast

